# Copy to .env and fill in real values:  cp .env.example .env

# NOTE: sync driver (sqlite:///), NOT sqlite+aiosqlite:/// — the project was
# converted to synchronous SQLAlchemy (aiosqlite/greenlet removed so pip
# install needs no C++/Rust toolchain on Python 3.14).
DATABASE_URL=sqlite:///./zazetech.db

# Generate one:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=замените-на-случайную-строку-минимум-32-символа

JWT_EXPIRE_MINUTES=60

# JSON array OR comma-separated — config.py accepts both.
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# development | production
NODE_ENV=development
